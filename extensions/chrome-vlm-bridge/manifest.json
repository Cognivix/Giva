{
  "manifest_version": 3,
  "name": "Giva VLM Bridge",
  "version": "0.1.0",
  "description": "Bridges Chrome to Giva's VLM browser automation — captures screenshots and executes visual actions.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:7483/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
